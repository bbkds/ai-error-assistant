    {"type":"singlestat","title":"Total Analyses","gridPos":{"x":0,"y":8,"w":6,"h":4},
     "targets":[{"expr":"http_requests_total{handler=\"/api/analyze\"}"}]}
  ],
  "schemaVersion":16,"version":1
